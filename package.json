{
  "name": "careerpath-ai",
  "version": "1.0.0",
  "description": "AI-powered career guidance system",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
