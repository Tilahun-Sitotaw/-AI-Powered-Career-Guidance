    "bcryptjs": "^2.4.3",
    "axios": "^1.3.0",
    "nodemailer": "^6.9.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^2.0.20",
    "concurrently": "^7.6.0"
  }
}
